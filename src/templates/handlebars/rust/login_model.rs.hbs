use serde::{Deserialize, Serialize};
use sqlx::FromRow;
use uuid::Uuid;


#[derive(Debug, FromRow, Serialize, Deserialize)]
pub struct AuthUser {
    pub id: Option<Uuid>,
    pub email: Option<String>,
    pub password: Option<String>,
}


#[derive(Deserialize)]
pub struct LoginRequest {
    pub email: Option<String>,
    pub password: Option<String>,
}
