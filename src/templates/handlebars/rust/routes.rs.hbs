use crate::handlers::*;
use crate::config::AppState;

pub fn create_router() -> Router<AppState> {
    Router::new()
    {{#each routes}}
        .route("{{ this.path }}", {{ this.method }}({{ this.model }}::get_{{ this.model }}))
    {{/each}}
}


